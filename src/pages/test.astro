---
import Layout from "../layouts/Layout.astro";

// imports

// types

// props

// logic, variables, functions, etc.
---

<Layout>
    <h1>This is a test page</h1>

    <div class="container">
        <div class="box"></div>
        <div class="box"></div>
        <div class="box"></div>
        <div class="box"></div>
        <div class="box"></div>
    </div>
</Layout>

<script>
    import gsap from "gsap";

    const container = document.querySelector(".container");
    const boxes = document.querySelectorAll(".box");
    const containerRect = container?.getBoundingClientRect();

    boxes.forEach((box) => {
        const boxRect = box.getBoundingClientRect();

        function cycle() {
            if (!containerRect) return;

            const newX = gsap.utils.random(
                0,
                containerRect.width - boxRect.width,
            );
            const newY = gsap.utils.random(
                0,
                containerRect.height - boxRect.height,
            );

            gsap.set(box, { x: newX, y: newY, opacity: 0, scale: 0.5 });

            gsap.to(box, {
                opacity: 1,
                scale: 1,
                duration: 0.5,
                onComplete: () => {
                    gsap.to(box, {
                        opacity: 0,
                        scale: 0.5,
                        duration: 0.5,
                        delay: 1,
                        onComplete: cycle,
                    });
                },
            });
        }

        gsap.delayedCall(gsap.utils.random(0, 2), cycle);
    });
</script>

<style>
    .container {
        position: relative;
        width: 100%;
        height: 100%;
        border: 1px solid red;
    }

    .box {
        position: absolute;
        width: 100px;
        height: 100px;
        background-color: #3498db;
        margin: 10px;
    }
</style>
