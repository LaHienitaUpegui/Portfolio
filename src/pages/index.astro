---
// imports
import Layout from "../layouts/Layout.astro";

// types

// props

// logic, variables, functions, etc.
---

<Layout>
    <div class="text-and-initial-button">
        <p class="initial-phrase">
            My portfolio is a counter, try and click it!
        </p>

        <a href="/portfolio-content" class="button-container">
            <svg class="border-svg">
                <rect
                    class="border-rect"
                    rx="8"
                    ry="8"
                    x="0"
                    y="0"
                    width="100%"
                    height="100%"></rect>
            </svg>

            <button transition:name="counter-button" class="visual-button"
                >Click me! Don't be shy! I don't bite!</button
            >
        </a>
    </div>
</Layout>

<script>
    import gsap from "gsap";
    import { DrawSVGPlugin } from "gsap/DrawSVGPlugin";
    gsap.registerPlugin(DrawSVGPlugin);

    const button = document.querySelector(".button-container");
    const initialPhrase = document.querySelector(".initial-phrase");
    const rect = document.querySelector(
        ".border-rect",
    ) as SVGGeometryElement | null;
    let initialAnimationTl = gsap.timeline();
    const borderPulseAnimation = gsap.to(rect, {
        opacity: 0,
        duration: 0.8,
        repeat: -1,
        yoyo: true,
        ease: "steps(1)",
        paused: true,
    });

    // Entry animation
    initialAnimationTl
        .from(button, {
            scale: 0.8,
            opacity: 0,
            duration: 1,
            ease: "back.out(1.7)",
        })
        .from(
            initialPhrase,
            {
                opacity: 0,
                y: 20,
                duration: 0.5,
                ease: "power2.out",
            },
            "-=0.3",
        );

    // Pulse animation for button border
    gsap.set(rect, {
        drawSVG: "0% 100%",
        opacity: 1,
    });
    borderPulseAnimation.play();

    // Hover and unhover animations for button
    button?.addEventListener("mouseenter", () => {
        gsap.to(".button-container", {
            scale: 1.05,
            duration: 0.3,
            ease: "power2.out",
        });

        borderPulseAnimation.pause();
    });

    button?.addEventListener("mouseleave", () => {
        gsap.to(".button-container", {
            scale: 1,
            duration: 0.3,
            ease: "power2.out",
        });

        borderPulseAnimation.play();
    });
</script>

<style>
    .text-and-initial-button {
        height: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: var(--gap-24px);
    }

    .text-and-initial-button p {
        color: var(--main-text-color);
    }

    .text-and-initial-button .button-container {
        position: relative;
        display: inline-block;
        padding: 2px;
        text-decoration: none;
    }

    .border-svg {
        position: absolute;
        top: -10px;
        left: -10px;
        width: calc(100% + 20px);
        height: calc(100% + 20px);
        overflow: visible !important;
        pointer-events: none;
        fill: none;
    }

    .border-rect {
        x: 5;
        y: 5;
        width: calc(100% - 10px);
        height: calc(100% - 10px);

        fill: none;
        stroke: var(--button-green-border);
        stroke-width: 3;
        stroke-linecap: round;

        filter: drop-shadow(0 0 8px var(--button-green-border));
    }

    .text-and-initial-button .visual-button {
        padding: var(--padding-8px) var(--padding-16px);
        border: 1px solid var(--button-green-border);
        border-radius: var(--radius-8px);
        background-color: var(--button-dark-purple-background);
        color: var(--main-text-color);
        cursor: pointer;

        font-family: "Inter", sans-serif;
        font-size: var(--fs-desktop-p-16px);
        font-weight: bold;

        height: 56px;
    }
</style>
