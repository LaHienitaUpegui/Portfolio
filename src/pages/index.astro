---

<Layout>
    <div class="text-and-initial-button">
        <p class="initial-phrase">
            My portfolio is a counter, try and click it!
        </p>

        <a href="/portfolio-content" class="button-container">
            <svg class="border-svg">
                <rect
                    class="border-rect"
                    rx="8"
                    ry="8"
                    x="0"
                    y="0"
                    width="100%"
                    height="100%"></rect>
            </svg>

            <button transition:name="counter-button" class="visual-button">
                <span class="button-text-full">Click me! Don't be shy! I don't bite!</span>
                <span class="button-text-short">Click me, I don't bite</span>
            </button>

            <div class="clickme-container clickme-bottom">
                <svg
                    id="Capa_2"
                    data-name="Capa 2"
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 21.59 42.68"
                    class="arrow-svg arrow-bottom"
                >
                    <g id="Elements">
                        <path
