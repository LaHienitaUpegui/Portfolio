                        ></path>
                    </g>
                </svg>
                <p class="clickme-text">Yes, click me!</p>
            </div>

            <div class="clickme-container clickme-left">
                <svg
                    id="Capa_2"
                    data-name="Capa 2"
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 21.59 42.68"
                    class="arrow-svg arrow-left"
                >
                    <g id="Elements">
                        <path
                            d="M21,20.86q-3.6-1.28-7.42-9.59c-.46,3.55-.83,6.06-1.09,8.58-.28,2.71-.54,5.42-.67,8.14-.18,3.68-.19,7.37-.38,11.05-.08,1.46.56,3.69-1.88,3.65-2.16-.04-2.16-2.19-2.13-3.69.09-5.44.29-10.87.64-16.3.2-3.02.77-6.01,1.25-9.54-3.82,3.08-4.65,8.13-9.32,10.67.09-1.6-.12-2.72.25-3.61C2.93,13.66,6.32,7.5,10.95,2.09c.41-.48.85-.98,1.37-1.34,1.93-1.34,3.98-.89,4.62,1.32,1.69,5.83,3.13,11.73,4.64,17.61.06.23-.26.55-.58,1.18Z"
                        ></path>
                    </g>
                </svg>
                <p class="clickme-text">Yes, click me!</p>
            </div>

            <div class="clickme-container clickme-right">
                <svg
                    id="Capa_2"
                    data-name="Capa 2"
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 21.59 42.68"
                    class="arrow-svg arrow-right"
                >
                    <g id="Elements">
                        <path
                            d="M21,20.86q-3.6-1.28-7.42-9.59c-.46,3.55-.83,6.06-1.09,8.58-.28,2.71-.54,5.42-.67,8.14-.18,3.68-.19,7.37-.38,11.05-.08,1.46.56,3.69-1.88,3.65-2.16-.04-2.16-2.19-2.13-3.69.09-5.44.29-10.87.64-16.3.2-3.02.77-6.01,1.25-9.54-3.82,3.08-4.65,8.13-9.32,10.67.09-1.6-.12-2.72.25-3.61C2.93,13.66,6.32,7.5,10.95,2.09c.41-.48.85-.98,1.37-1.34,1.93-1.34,3.98-.89,4.62,1.32,1.69,5.83,3.13,11.73,4.64,17.61.06.23-.26.55-.58,1.18Z"
                        ></path>
                    </g>
                </svg>
                <p class="clickme-text">Yes, click me!</p>
            </div>
        </a>
    </div>
</Layout>

<script>
    import gsap from "gsap";
    import { DrawSVGPlugin } from "gsap/DrawSVGPlugin";
    gsap.registerPlugin(DrawSVGPlugin);

    const button = document.querySelector(".button-container");
    const initialPhrase = document.querySelector(".initial-phrase");

    const clickMeContainers = document.querySelectorAll(".clickme-container");
    clickMeContainers.forEach((container) => {
        gsap.set(container, {
            opacity: 0,
            pointerEvents: "none",
        });
    });

    const rect = document.querySelector(
        ".border-rect",
    ) as SVGGeometryElement | null;
    const initialAnimationTl = gsap.timeline();
    const borderPulseAnimation = gsap.to(rect, {
        opacity: 0,
        duration: 0.8,
        repeat: -1,
        yoyo: true,
        ease: "steps(1)",
        paused: true,
    });

    // Entry animation
    initialAnimationTl
        .from(button, {
            scale: 0.8,
            opacity: 0,
            duration: 1,
            ease: "back.out(1.7)",
        })
        .from(
            initialPhrase,
            {
                opacity: 0,
                y: 20,
                duration: 0.5,
                ease: "power2.out",
            },
            "-=0.3",
        );

    // Pulse animation for button border
    gsap.set(rect, {
        drawSVG: "0% 100%",
        opacity: 1,
    });
    borderPulseAnimation.play();

    const arrowAnimations: gsap.core.Tween[] = [];

    const arrowConfigs = {
        ".arrow-bottom": {
            from: { y: -15 },
            to: { y: 2, ease: "power1.inOut" },
        },
        ".arrow-left": { from: { x: -2 }, to: { x: 15, ease: "power1.inOut" } },
        ".arrow-right": {
            from: { x: 2 },
            to: { x: -15, ease: "power1.inOut" },
        },
    };

    function createArrowAnimation(
        container: Element,
        selector: string,
        config: { from: gsap.TweenVars; to: gsap.TweenVars },
    ) {
        const arrow = container.querySelector(selector) as Element | null;
        if (!arrow) return;
        gsap.set(arrow, config.from);
        const anim = gsap.fromTo(arrow, config.from, {
            ...config.to,
            duration: 0.5,
            repeat: -1,
            yoyo: true,
        });
        arrowAnimations.push(anim);
    }

    function clearArrowAnimations() {
        arrowAnimations.forEach((anim) => anim.kill());
        arrowAnimations.length = 0;
    }

    // Hover and unhover animations for button
    button?.addEventListener("mouseenter", () => {
        gsap.to(".button-container", {
            scale: 1.05,
            duration: 0.3,
            ease: "power2.out",
        });

        borderPulseAnimation.pause();

        clickMeContainers.forEach((container) => {
            gsap.to(container, { opacity: 1 });
            createArrowAnimation(
                container,
                ".arrow-bottom",
                arrowConfigs[".arrow-bottom"],
            );
            createArrowAnimation(
                container,
                ".arrow-left",
                arrowConfigs[".arrow-left"],
            );
            createArrowAnimation(
                container,
                ".arrow-right",
                arrowConfigs[".arrow-right"],
            );
        });
    });

    button?.addEventListener("mouseleave", () => {
        gsap.to(".button-container", {
            scale: 1,
            duration: 0.3,
            ease: "power2.out",
        });

        borderPulseAnimation.play();
        clearArrowAnimations();

        clickMeContainers.forEach((container) => {
            gsap.to(container, { opacity: 0 });
        });
    });
</script>

<style>
    .text-and-initial-button {
        height: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: var(--gap-24px);
    }

    .text-and-initial-button .initial-phrase {
        color: var(--main-text-color);
    }

    .text-and-initial-button .button-container {
        position: relative;
        display: inline-block;
        padding: 2px;
        text-decoration: none;
    }

    .border-svg {
        position: absolute;
        top: -10px;
        left: -10px;
        width: calc(100% + 20px);
        height: calc(100% + 20px);
        overflow: visible !important;
        pointer-events: none;
        fill: none;
    }

    .border-rect {
        x: 5;
        y: 5;
        width: calc(100% - 10px);
        height: calc(100% - 10px);

        fill: none;
        stroke: var(--button-green-border);
        stroke-width: 3;
        stroke-linecap: round;

        filter: drop-shadow(0 0 8px var(--button-green-border));
    }

    .text-and-initial-button .visual-button {
        padding: var(--padding-8px) var(--padding-16px);
        border: 1px solid var(--button-green-border);
        border-radius: var(--radius-8px);
        background-color: var(--button-dark-purple-background);
        color: var(--main-text-color);
        cursor: pointer;

        font-family: "Inter", sans-serif;
        font-size: var(--fs-desktop-p-16px);
        font-weight: bold;

        height: 56px;
    }

    .clickme-bottom {
        position: absolute;
        top: 220%;
        left: 50%;
        transform: translate(-50%, -50%);
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: var(--gap-8px);
    }

    .clickme-left {
        width: 100%;
        position: absolute;
        top: 50%;
        left: -30%;
        transform: translate(-50%, -50%);
        display: flex;
        align-items: center;
        gap: var(--gap-8px);

        & .arrow-left {
            transform: rotate(90deg);
            order: 2;
        }
    }

    .clickme-right {
        width: 100%;
        position: absolute;
        top: 50%;
        left: 160%;
        transform: translate(-50%, -50%);
        display: flex;
        align-items: center;
        gap: var(--gap-8px);

        & .arrow-right {
            transform: rotate(-90deg);
        }
    }

    .clickme-text {
        font-family: "Neue Comic", sans-serif;
        font-size: var(--fs-desktop-h5-24px);
        font-weight: bold;
        color: var(--main-text-color);
    }

    .arrow-svg {
        fill: var(--white);
        width: 50px;
        height: 50px;
    }

    /* Mobile - max-width: 767px */
    @media (max-width: 767px) {
        .text-and-initial-button {
            width: 100%;
            padding: 0 var(--padding-16px);
            text-align: center;
            min-height: 60vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            gap: var(--gap-24px);
        }

        .text-and-initial-button .initial-phrase {
            font-size: var(--fs-mobile-p-16px);
            width: 100%;
        }

        .text-and-initial-button .button-container {
            display: block;
            width: 100%;
            max-width: 300px;
        }

        .text-and-initial-button .visual-button {
            font-size: var(--fs-mobile-p-16px);
            width: 100%;
            padding: var(--padding-12px) var(--padding-16px);
            min-height: 60px;
            white-space: normal;
            text-align: center;
            line-height: 1.3;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }

        .button-text-short {
            display: none;
        }

        @media (max-width: 767px) {
            .button-text-full {
                display: none;
            }

            .button-text-short {
                display: inline;
            }
        }

        .clickme-bottom,
        .clickme-left,
        .clickme-right {
            display: none;
        }
    }
</style>
