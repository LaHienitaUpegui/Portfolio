<style>
    * {
        box-sizing: border-box;
    }

    html,
    body {
        margin: 0;
        width: 100%;
        height: 100vh;
    }

    body {
        display: flex;
        flex-direction: column;
        gap: var(--gap-48px);

        background: var(--dark-purple)
            url("../assets/images/fondo_grid_10opacity.webp") repeat center
            center fixed;

        padding-top: 32px;
        padding-bottom: 32px;
    }

    header {
        display: flex;
        justify-content: space-between;
        align-items: center;

        padding: var(--padding-24px) var(--padding-64px);

        & p {
            color: var(--white);
            font-weight: bold;
        }
    }

    main {
        flex: 1;
        max-width: 1500px;
        margin: 0 auto;
        padding: var(--padding-0px) var(--padding-64px);
    }

    footer {
        display: flex;
        justify-content: space-between;
        align-items: center;

        padding: var(--padding-24px) var(--padding-64px);

        & p {
            color: var(--white);
        }

        .footer-content {
            display: flex;
            align-items: center;
            gap: var(--gap-16px);
        }

        .icons-container {
            display: flex;
            align-items: center;
            gap: var(--gap-16px);
        }
    }

    ::-webkit-scrollbar {
        display: none;
    }
</style>
